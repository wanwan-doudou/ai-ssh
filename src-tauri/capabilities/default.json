{
  "identifier": "main-capability",
  "description": "Main app capability",
  "windows": ["main", "editor-*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }]
    }
  ]
}
